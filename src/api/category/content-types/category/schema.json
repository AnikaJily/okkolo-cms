{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Категория шоурума",
    "description": "Справочник категорий товаров. Заводится контент-менеджером без правки кода."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Отображаемое название, напр. «Керамика»."
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "description": "Ключ для фильтра/URL. Уникален — защищает от дублей."
    },
    "order": {
      "type": "integer",
      "default": 0,
      "description": "Порядок чипов-фильтров: меньше — левее."
    },
    "products": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product",
      "mappedBy": "category",
      "description": "Товары этой категории."
    }
  }
}
