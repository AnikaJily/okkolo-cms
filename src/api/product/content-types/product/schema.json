{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Товары"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "integer"
    },
    "categoryName": {
      "type": "string",
      "customField": "global::category-name",
      "description": "Начните вводить — покажем похожие категории; выберите существующую или добавьте новую. На сохранении привяжется связь «Категория». Дубли по регистру не плодятся."
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products",
      "description": "Заполняется автоматически из «categoryName». Можно не трогать."
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "cartUrl": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "isAvailable": {
      "type": "boolean",
      "default": true,
      "description": "Снять галочку, чтобы временно скрыть товар (например, нет в наличии). Удалять не обязательно."
    }
  }
}
