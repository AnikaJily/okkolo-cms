{
  "kind": "collectionType",
  "collectionName": "about_team_photos",
  "info": {
    "singularName": "about-team-photo",
    "pluralName": "about-team-photos",
    "displayName": "О нас — фото команды",
    "description": "Члены команды (фото + имя + должность) для блока «Команда» на /about."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "name": {
      "type": "string",
      "required": true,
      "description": "Имя члена команды (читается скринридером, отдельный alt не нужен)."
    },
    "role": {
      "type": "string",
      "description": "Должность/роль, напр. «бариста»."
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
