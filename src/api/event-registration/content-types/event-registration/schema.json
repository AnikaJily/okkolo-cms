{
  "kind": "collectionType",
  "collectionName": "event_registrations",
  "info": {
    "singularName": "event-registration",
    "pluralName": "event-registrations",
    "displayName": "Регистрация на мероприятия"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "eventTitle": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "comment": {
      "type": "text"
    },
    "eventId": {
      "type": "string",
      "description": "Устар.: оставлено для совместимости с лендингом. Источник истины — связь event."
    },
    "event": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event.event",
      "inversedBy": "registrations",
      "description": "Мероприятие, на которое подана регистрация."
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "not_required",
        "paid"
      ],
      "description": "pending — ждёт оплаты, not_required — оплата не нужна (бесплатное событие), paid — оплачено."
    }
  }
}
