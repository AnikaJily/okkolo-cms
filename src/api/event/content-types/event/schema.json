{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Мероприятия"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "description": "Используется в URL: /events/<slug>. Заполняется автоматически из заголовка."
    },
    "date": {
      "type": "datetime"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "description": "Дополнительные фото для слайдера на детальной странице. Первое фото — обложка (photo)."
    },
    "description": {
      "type": "text"
    },
    "isPaid": {
      "type": "boolean",
      "default": false
    },
    "price": {
      "type": "integer",
      "description": "Цена в рублях, если событие платное."
    },
    "paymentUrl": {
      "type": "string"
    },
    "typeName": {
      "type": "string",
      "customField": "global::event-type-name",
      "description": "Начните вводить — покажем похожие типы; выберите существующий или добавьте новый. На сохранении привяжется связь «Тип». Дубли по регистру не плодятся."
    },
    "type": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::event-type.event-type",
      "inversedBy": "events",
      "description": "Заполняется автоматически из «typeName». Менять вручную не нужно."
    },
    "spotsTotal": {
      "type": "integer"
    },
    "spotsTaken": {
      "type": "integer"
    },
    "registrations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::event-registration.event-registration",
      "mappedBy": "event",
      "description": "Регистрации на это мероприятие. Кол-во = занятые места."
    }
  }
}
