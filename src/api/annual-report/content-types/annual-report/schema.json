{
  "kind": "collectionType",
  "collectionName": "annual_reports",
  "info": {
    "singularName": "annual-report",
    "pluralName": "annual-reports",
    "displayName": "Годовые отчёты",
    "description": "Годовая отчётность фонда. На сайте группируется по году. У каждого года может быть несколько типов отчётов (содержательный, финансовый, в Минюст, расходование средств)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "year": {
      "type": "integer",
      "required": true,
      "min": 2020,
      "max": 2100
    },
    "kind": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "content",
        "finance",
        "nko-activity",
        "spending"
      ],
      "description": "content — содержательный, finance — финансовый, nko-activity — отчёт о деятельности НКО, spending — отчёт о целях расходования."
    },
    "pdf": {
      "type": "media",
      "required": true,
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "note": {
      "type": "text",
      "description": "Дополнительная подпись к отчёту (опционально)."
    }
  }
}
