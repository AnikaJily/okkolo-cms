{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Заказ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "customerName": {
      "type": "string",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email"
    },
    "itemsSubtotal": {
      "type": "integer"
    },
    "deliveryPrice": {
      "type": "integer"
    },
    "totalPrice": {
      "type": "integer"
    },
    "items": {
      "type": "json"
    },
    "orderStatus": {
      "type": "enumeration",
      "enum": [
        "pending",
        "completed"
      ]
    },
    "fulfillmentType": {
      "type": "enumeration",
      "enum": [
        "pickup",
        "delivery"
      ]
    },
    "city": {
      "type": "string"
    },
    "address": {
      "type": "string"
    },
    "deliveryComment": {
      "type": "text"
    }
  }
}
