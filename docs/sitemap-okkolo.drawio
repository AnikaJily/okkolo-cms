        <mxCell id="band" value="&lt;b&gt;Глобальная навигация — на каждой странице.&lt;/b&gt;&amp;nbsp;&amp;nbsp; &lt;b&gt;Шапка:&lt;/b&gt; логотип → «Главная» · меню разделов · бургер = полное меню.&amp;nbsp;&amp;nbsp; &lt;b&gt;Подвал:&lt;/b&gt; ссылки на все разделы · контакты · соцсети · правовые страницы." style="rounded=1;arcSize=6;whiteSpace=wrap;html=1;dashed=1;fillColor=#eef0f2;strokeColor=#9aa0a6;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12;spacingRight=12;" vertex="1" parent="1"><mxGeometry x="40" y="34" width="1405" height="44" as="geometry"/></mxCell>
        <mxCell id="legalbox" value="Служебные / правовые страницы — доступ из подвала (на всех страницах)" style="rounded=1;html=1;whiteSpace=wrap;dashed=1;fillColor=#fbfbfb;strokeColor=#bdbdbd;verticalAlign=top;align=left;fontSize=11;fontColor=#777777;spacingTop=6;spacingLeft=10;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="423" height="110" as="geometry"/></mxCell>
